{
  "manifest_version": 3,
  "name": "Unlimited Games — Free Browser Games",
  "short_name": "Unlimited Games",
  "version": "1.0.0",
  "description": "A growing collection of free browser games: snake, chess, fishing, fighting, a 3D liar's bar, and more. No downloads, no logins.",
  "homepage_url": "https://unlimitedgames.vercel.app",
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Open Unlimited Games"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [],
  "host_permissions": []
}
